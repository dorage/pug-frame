{
  "name": "canvas",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/canvas/src",
  "projectType": "library",
  "implicitDependencies": ["render"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build",
        "cwd": "packages/canvas"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "vitest run",
        "cwd": "packages/canvas"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite demo",
        "cwd": "packages/canvas"
      }
    }
  }
}
