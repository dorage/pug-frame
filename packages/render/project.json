{
  "name": "render",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/render/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p tsconfig.json",
        "cwd": "packages/render"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "packages/render"
      }
    }
  }
}
